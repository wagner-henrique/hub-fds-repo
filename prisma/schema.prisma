generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
}

enum UserRole {
  ADMIN
  RECEPTION
}

enum ClientType {
  PF
  PJ
}

enum CrmDealStage {
  LEAD
  CONTACT
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum CrmActivityType {
  NOTE
  CALL
  MEETING
  EMAIL
  WHATSAPP
}

model Booking {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  room      String        @default("reuniao")
  date      DateTime
  time      String
  status    BookingStatus @default(PENDING)
  notes     String?
  clientId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([room, date, time])
  @@index([date, room, status])
  @@index([createdAt])
  @@index([clientId])
}

model Lead {
  id        String     @id @default(cuid())
  name      String?
  email     String
  phone     String?
  source    String     @default("landing_page")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email])
}

model Setting {
  id        String   @id @default("system_config")
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(RECEPTION)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id          String     @id @default(cuid())
  name        String
  type        ClientType @default(PF)
  email       String     @unique
  phone       String
  whatsapp    String?
  cpf         String?    @unique
  cnpj        String?    @unique
  birthDate   DateTime?
  address     String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  bookings Booking[]
  deals    CrmDeal[]
  tasks    CrmTask[]
  activities CrmActivity[]

  @@index([name])
  @@index([email])
  @@index([phone])
}

model CrmDeal {
  id                String      @id @default(cuid())
  title             String
  description       String?
  value             Float       @default(0)
  stage             CrmDealStage @default(LEAD)
  expectedCloseDate DateTime?
  source            String?
  clientId          String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks      CrmTask[]
  activities CrmActivity[]

  @@index([clientId])
  @@index([stage])
  @@index([expectedCloseDate])
}

model CrmTask {
  id          String          @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      CrmTaskStatus   @default(OPEN)
  priority    CrmTaskPriority @default(MEDIUM)
  clientId    String?
  dealId      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  client Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal   CrmDeal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([dealId])
  @@index([status])
  @@index([dueDate])
}

model CrmActivity {
  id        String          @id @default(cuid())
  type      CrmActivityType @default(NOTE)
  content   String
  clientId  String?
  dealId    String?
  createdAt DateTime        @default(now())

  client Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal   CrmDeal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([dealId])
  @@index([type])
  @@index([createdAt])
}
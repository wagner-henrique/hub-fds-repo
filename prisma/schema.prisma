generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  LOST
}

enum UserRole {
  ADMIN
  RECEPTION
}

enum ClientType {
  PF
  PJ
}

enum CrmDealStage {
  LEAD
  CONTACT
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CrmTaskStatus {
  OPEN
  IN_PROGRESS
  DONE
  CANCELED
}

enum CrmTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum CrmActivityType {
  NOTE
  CALL
  MEETING
  EMAIL
  WHATSAPP
}

enum ContractType {
  UPLOADED
  GENERATED
}

enum FinancialEntryType {
  PAYABLE
  RECEIVABLE
}

enum FinancialEntryStatus {
  PENDING
  PARTIAL
  PAID
  CANCELED
}

enum BillingStatus {
  DRAFT
  ISSUED
  PARTIAL
  PAID
  CANCELED
  OVERDUE
}

model Booking {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  room      String        @default("reuniao")
  date      DateTime
  time      String
  status    BookingStatus @default(PENDING)
  notes     String?
  clientId  String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@unique([room, date, time])
  @@index([date, room, status])
  @@index([createdAt])
  @@index([clientId])
}

model Lead {
  id        String     @id @default(cuid())
  name      String?
  email     String
  phone     String?
  source    String     @default("landing_page")
  status    LeadStatus @default(NEW)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([email])
}

model Setting {
  id        String   @id @default("system_config")
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(RECEPTION)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id          String     @id @default(cuid())
  name        String
  type        ClientType @default(PF)
  email       String     @unique
  phone       String
  whatsapp    String?
  cpf         String?    @unique
  cnpj        String?    @unique
  birthDate   DateTime?
  address     String?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  bookings Booking[]
  deals    CrmDeal[]
  tasks    CrmTask[]
  activities CrmActivity[]
  contracts Contract[]
  financialEntries FinancialEntry[]
  invoices Invoice[]

  @@index([name])
  @@index([email])
  @@index([phone])
}

model Contract {
  id            String       @id @default(cuid())
  title         String
  type          ContractType
  clientId      String
  fileName      String?
  mimeType      String?
  fileData      Bytes?
  generatedHtml String?
  metadata      Json?
  createdBy     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([type])
  @@index([createdAt])
}

model FinancialEntry {
  id            String               @id @default(cuid())
  type          FinancialEntryType
  status        FinancialEntryStatus @default(PENDING)
  title         String
  description   String?
  category      String?
  amount        Float
  amountPaid    Float                @default(0)
  dueDate       DateTime
  paymentDate   DateTime?
  referenceCode String?
  clientId      String?
  createdBy     String?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([type, status])
  @@index([dueDate])
  @@index([paymentDate])
  @@index([clientId])
}

model Invoice {
  id                 String        @id @default(cuid())
  number             String        @unique
  status             BillingStatus @default(DRAFT)
  title              String
  clientId           String
  issueDate          DateTime
  dueDate            DateTime
  servicePeriodStart DateTime?
  servicePeriodEnd   DateTime?
  items              Json
  subtotal           Float
  discount           Float         @default(0)
  tax                Float         @default(0)
  total              Float
  paidAmount         Float         @default(0)
  balance            Float
  paymentMethod      String?
  referenceCode      String?
  notes              String?
  createdBy          String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([status, dueDate])
  @@index([clientId, issueDate])
  @@index([createdAt])
}

model CrmDeal {
  id                String      @id @default(cuid())
  title             String
  description       String?
  value             Float       @default(0)
  stage             CrmDealStage @default(LEAD)
  expectedCloseDate DateTime?
  source            String?
  clientId          String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  client     Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tasks      CrmTask[]
  activities CrmActivity[]

  @@index([clientId])
  @@index([stage])
  @@index([expectedCloseDate])
}

model CrmTask {
  id          String          @id @default(cuid())
  title       String
  description String?
  dueDate     DateTime?
  status      CrmTaskStatus   @default(OPEN)
  priority    CrmTaskPriority @default(MEDIUM)
  clientId    String?
  dealId      String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  client Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal   CrmDeal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([dealId])
  @@index([status])
  @@index([dueDate])
}

model CrmActivity {
  id        String          @id @default(cuid())
  type      CrmActivityType @default(NOTE)
  content   String
  clientId  String?
  dealId    String?
  createdAt DateTime        @default(now())

  client Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  deal   CrmDeal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([dealId])
  @@index([type])
  @@index([createdAt])
}